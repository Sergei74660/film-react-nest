# Переменные для docker-compose (используются сервисами db, pgadmin, backend)

# PostgreSQL
POSTGRES_DB=prac
POSTGRES_USER=prac
POSTGRES_PASSWORD=1234

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=1234

# Backend — внутри docker-сети СУБД доступна по имени сервиса "db",
# а не по localhost (для локального запуска без Docker используйте
# backend/.env, где DATABASE_URL указывает на localhost)
DATABASE_DRIVER=postgres
DATABASE_URL=postgres://db:5432/prac
DATABASE_USERNAME=prac
DATABASE_PASSWORD=1234
LOGGER_TYPE=json
